generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Coin {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  name      String
  createdAt DateTime
  updatedAt DateTime

  marketData CoinMarketData[]
  holdings   Holding[]
  trades     Trade[]
}

model CoinMarketData {
  id           Int      @id @default(autoincrement())
  coinId       Int
  snapshotDate DateTime @db.Date
  priceUsd     Decimal  @db.Decimal(18, 8)
  marketCap    Decimal  @db.Decimal(24, 2)
  volume24h    Decimal  @db.Decimal(24, 2)
  createdAt    DateTime

  coin Coin @relation(fields: [coinId], references: [id])

  @@unique([coinId, snapshotDate])
  @@index([snapshotDate])
}

model User {
  id              String   @id @default(cuid())
  name            String
  description     String?
  startingBalance Decimal  @db.Decimal(18, 2)
  currentBalance  Decimal  @db.Decimal(18, 2)
  createdAt       DateTime

  holdings    Holding[]
  trades      Trade[]
  dailyAssets UserDailyAsset[]
}

model Holding {
  id        String   @id @default(cuid())
  userId    String
  coinId    Int
  quantity  Decimal  @db.Decimal(24, 8)
  avgPrice  Decimal  @db.Decimal(18, 8)
  createdAt DateTime
  updatedAt DateTime

  user User @relation(fields: [userId], references: [id])
  coin Coin @relation(fields: [coinId], references: [id])

  @@unique([userId, coinId])
  @@index([coinId])
}

model Trade {
  id          String    @id @default(cuid())
  userId      String
  coinId      Int
  type        TradeType
  quantity    Decimal   @db.Decimal(24, 8)
  priceUsd    Decimal   @db.Decimal(18, 8)
  totalAmount Decimal   @db.Decimal(18, 2)
  createdAt   DateTime

  user User @relation(fields: [userId], references: [id])
  coin Coin @relation(fields: [coinId], references: [id])

  @@index([userId, createdAt])
  @@index([coinId])
}

model UserDailyAsset {
  id           String   @id @default(cuid())
  userId       String
  snapshotDate DateTime @db.Date
  cashBalance  Decimal  @db.Decimal(18, 2)
  assetValue   Decimal  @db.Decimal(18, 2)
  totalValue   Decimal  @db.Decimal(18, 2)
  createdAt    DateTime

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, snapshotDate])
  @@index([snapshotDate])
}

enum TradeType {
  BUY
  SELL
}
